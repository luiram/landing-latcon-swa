# Copiar este archivo a .env.local y ajustar ( .env*.local está en .gitignore )
#
# URL del Function App SIN barra final. El front llama a ${NEXT_PUBLIC_FUNCTIONS_BASE_URL}/api/slots etc.
# - Desarrollo local si ejecutas Functions con "func start" en api/:  http://localhost:7071
# - Producción (ejemplo): https://func-latcon-booking-prd-euemhuf7drh3emac.centralus-01.azurewebsites.net
NEXT_PUBLIC_FUNCTIONS_BASE_URL=http://localhost:7071

# ID de medición de Google Analytics 4 (formato G-XXXXXXXXXX). Opcional: si se deja vacío,
# el componente GoogleAnalytics no carga ningún script (útil en desarrollo local).
NEXT_PUBLIC_GA_MEASUREMENT_ID=
