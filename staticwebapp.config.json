{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/images/*.{png,jpg,gif,webp,svg}", "/*.{css,js,map,json,ico,txt,webmanifest}"]
  },
  "globalHeaders": {
    "/*": {
      "X-Content-Type-Options": "nosniff",
      "Referrer-Policy": "strict-origin-when-cross-origin"
    }
  },
  "mimeTypes": {
    ".webmanifest": "application/manifest+json"
  }
}
